# Google Maps (não necessário para iframe embed simples)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=sua_chave_aqui

# Futura integração de e-mail (ex: Resend, SendGrid, Brevo)
# RESEND_API_KEY=sua_chave_aqui
# SENDGRID_API_KEY=sua_chave_aqui
# BREVO_API_KEY=sua_chave_aqui

# URL pública do site
# NEXT_PUBLIC_SITE_URL=https://instituto.com.br

# Analytics (opcional)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTAG_ID=

# API Base URL (se houver backend futuro)
# NEXT_PUBLIC_API_BASE_URL=https://api.instituto.com.br
